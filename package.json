{
    "name": "ai-process-kb",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "dev:server": "node server/index.mjs",
        "wiki:vault:init": "node scripts/wiki-vault.mjs init",
        "wiki:vault:publish": "node scripts/wiki-vault.mjs publish --limit 10",
        "wiki:vault:rebuild-index": "node scripts/wiki-vault.mjs rebuild-index",
        "openclaw:preview": "node scripts/openclaw-knowledge.mjs preview",
        "openclaw:import": "node scripts/openclaw-knowledge.mjs import",
        "build": "vue-tsc --noEmit && vite build",
        "build:analyze": "ANALYZE=1 vite build",
        "bundle:check": "node scripts/check-bundle-size.mjs",
        "preview": "vite preview",
        "typecheck": "vue-tsc --noEmit",
        "arch:check": "node scripts/check-architecture.mjs",
        "docs:api:check": "node scripts/check-api-docs.mjs",
        "docs:api:check:public": "node scripts/check-api-public-docs.mjs",
        "quality:check": "npm run arch:check && npm run typecheck && npm run build && npm run bundle:check && npm run test --if-present",
        "git:hooks:install": "node scripts/install-git-hooks.mjs",
        "git:task": "node scripts/git-task.mjs",
        "git:task:start": "node scripts/git-task.mjs start",
        "git:task:commit": "node scripts/git-task.mjs commit",
        "git:task:snapshot": "node scripts/git-task.mjs snapshot",
        "git:task:finish": "node scripts/git-task.mjs finish",
        "adapt:exports": "node scripts/adapt-exports.mjs",
        "score:prompt": "node scripts/score-prompts.mjs",
        "optimize:prompt": "node scripts/optimize-prompt.mjs"
    },
    "dependencies": {
        "@codemirror/commands": "^6.10.3",
        "@codemirror/lang-css": "^6.3.1",
        "@codemirror/lang-go": "^6.0.1",
        "@codemirror/lang-html": "^6.4.11",
        "@codemirror/lang-java": "^6.0.2",
        "@codemirror/lang-javascript": "^6.2.5",
        "@codemirror/lang-json": "^6.0.2",
        "@codemirror/lang-markdown": "^6.5.0",
        "@codemirror/lang-python": "^6.2.1",
        "@codemirror/lang-xml": "^6.1.0",
        "@codemirror/lang-yaml": "^6.1.3",
        "@codemirror/language": "^6.12.3",
        "@codemirror/merge": "^6.12.1",
        "@codemirror/state": "^6.6.0",
        "@codemirror/view": "^6.41.0",
        "@vueuse/core": "^14.2.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "diff2html": "^3.4.56",
        "dompurify": "^3.3.3",
        "lucide-vue-next": "^1.0.0",
        "marked": "^17.0.5",
        "reka-ui": "^2.9.2",
        "tailwind-merge": "^3.5.0",
        "tailwindcss-animate": "^1.0.7",
        "vue": "^3.5.15"
    },
    "devDependencies": {
        "@vitejs/plugin-vue": "^5.2.4",
        "autoprefixer": "^10.4.27",
        "postcss": "^8.5.8",
        "rollup-plugin-visualizer": "^7.0.1",
        "tailwindcss": "^3.4.17",
        "typescript": "^5.8.3",
        "vite": "^5.4.17",
        "vue-tsc": "^2.2.10"
    }
}
